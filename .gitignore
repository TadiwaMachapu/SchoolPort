# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# EF migrations are SOURCE CODE and must be versioned. They were ignored until
# Sprint 1.5.0, which is why the repo held no migrations and the live DB history
# drifted from the repo (see CLAUDE.md "Migration chain notes"). Do not re-ignore.

# Generated backfill reports contain live user emails (PII) — never commit.
SchoolPortal.Server/backfill-identity-report.md

# Logs
logs/
*.log

# Database files (local development)
*.mdf
*.ldf
*.ndf

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Rider
.idea/
*.sln.iml

# Backup files
*.bak
*.backup

# Sensitive configuration
appsettings.Production.json
*.pfx
*.p12

# Node
node_modules/
.next/
out/
.env.local
.env*.local

# Obsidian vault app-state and plugins (the obsidian-git plugin fired a 53k-line
# "vault backup" commit onto a working branch during Sprint 1.5.1 — vault config
# and plugin binaries are not project source). Ignoring .obsidian everywhere
# supersedes the plugin's own narrower workspace/cache entries.
**/.obsidian/
SchoolPort/.trash/