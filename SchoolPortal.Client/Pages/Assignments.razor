@page "/assignments"
@attribute [Authorize(Roles = "Admin,Teacher,Student")]
@inject IAssignmentService AssignmentService
@inject IClassService ClassService
@inject NavigationManager Navigation

<PageTitle>Assignments</PageTitle>

<div class="assignments-page">
    <div class="page-header">
        <h1>Assignments</h1>
        <AuthorizeView Roles="Admin,Teacher" Context="createButtonAuth">
            <button class="btn btn-primary" @onclick="ShowCreateModal">Create Assignment</button>
        </AuthorizeView>
    </div>

    <div class="filters">
        <label>Filter by Class:</label>
        <select @bind="selectedClassId" @bind:after="LoadAssignments" class="form-control">
            <option value="">All Classes</option>
            @if (classes != null)
            {
                @foreach (var cls in classes.Items)
                {
                    <option value="@cls.ClassId">@cls.Name</option>
                }
            }
        </select>
    </div>

    @if (isLoading)
    {
        <p><em>Loading assignments...</em></p>
    }
    else if (assignments != null && assignments.Items.Any())
    {
        <div class="assignments-grid">
            @foreach (var assignment in assignments.Items)
            {
                <div class="assignment-card">
                    <h4>@assignment.Title</h4>
                    <p>@assignment.Description</p>
                    <div class="assignment-meta">
                        <span><strong>Class:</strong> @assignment.ClassName</span>
                        <span><strong>Subject:</strong> @assignment.SubjectName</span>
                        <span><strong>Due:</strong> @assignment.DueAt.ToString("MMM dd, yyyy")</span>
                        <span><strong>Max Marks:</strong> @assignment.MaxMarks</span>
                    </div>
                    <div class="assignment-actions">
                        <button class="btn btn-sm btn-info" @onclick="() => ViewAssignment(assignment.AssignmentId)">View Details</button>
                        <AuthorizeView Roles="Student" Context="submitButtonAuth">
                            <button class="btn btn-sm btn-success" @onclick="() => SubmitAssignment(assignment.AssignmentId)">Submit</button>
                        </AuthorizeView>
                    </div>
                </div>
            }
        </div>

        <div class="pagination">
            <button class="btn btn-secondary" @onclick="PreviousPage" disabled="@(currentPage <= 1)">Previous</button>
            <span>Page @currentPage of @totalPages</span>
            <button class="btn btn-secondary" @onclick="NextPage" disabled="@(currentPage >= totalPages)">Next</button>
        </div>
    }
    else
    {
        <p>No assignments found.</p>
    }
</div>

@code {
    private PaginatedResult<AssignmentDto>? assignments;
    private PaginatedResult<ClassDto>? classes;
    private bool isLoading = true;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => assignments != null ? (int)Math.Ceiling((double)assignments.Total / pageSize) : 0;
    private string selectedClassId = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadClasses();
        await LoadAssignments();
    }

    private async Task LoadClasses()
    {
        classes = await ClassService.GetClassesAsync(1, 100);
    }

    private async Task LoadAssignments()
    {
        isLoading = true;
        try
        {
            int? classId = string.IsNullOrEmpty(selectedClassId) ? null : int.Parse(selectedClassId);
            assignments = await AssignmentService.GetAssignmentsAsync(classId, currentPage, pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadAssignments();
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadAssignments();
        }
    }

    private void ViewAssignment(Guid id)
    {
        Navigation.NavigateTo($"/assignments/{id}");
    }

    private void SubmitAssignment(Guid id)
    {
        Navigation.NavigateTo($"/assignments/{id}/submit");
    }

    private void ShowCreateModal()
    {
        Navigation.NavigateTo("/assignments/create");
    }
}
